<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UserProfileActivity01"
    android:background="@color/white"
    >
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@android:color/transparent"
        android:src="@drawable/chevron_left"
        android:contentDescription="@string/app_name"
        android:layout_gravity="start|bottom"/>

    <ProgressBar
        android:layout_width="match_parent"
        android:id="@+id/topProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_height="8dp"
        android:layout_marginTop="55dp"
        android:max="100"
        android:progress="60"
        android:progressDrawable="@drawable/custom_progress_bar_green" />

    <ImageView
        android:id="@+id/cachorro_acariciado"
        android:layout_width="320dp"
        android:layout_height="135dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="105dp"
        android:layout_marginEnd="41dp"
        android:src="@drawable/cachorro_bolo3" />


    <TextView
        android:id="@+id/textDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="240dp"
        android:layout_marginEnd="0dp"
        android:gravity="center"
        android:fontFamily="@font/solway_regular"
        android:textSize="24sp"
        android:text="O aniversário do seu bichinho \né:" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/buttonSelectDate"
        android:layout_width="250dp"
        android:layout_height="47dp"
        android:layout_below="@id/textDescription"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:text="Selecionar Data"
        android:fontFamily="@font/solway_regular"
        android:background="@drawable/rounded_corner"
        android:textAllCaps="false"
        android:textSize="16sp" />


    <TextView
        android:id="@+id/textSelectedDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/buttonSelectDate"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:text=""
        android:textSize="16sp"
        android:fontFamily="@font/solway_regular" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button2"
        android:layout_width="200dp"
        android:layout_height="45dp"
        android:layout_below="@+id/buttonSelectDate"
        android:layout_marginTop="180dp"
        android:layout_centerHorizontal="true"
        android:background="@drawable/rounded_corner"
        android:backgroundTint="#38C075"
        android:fontFamily="@font/solway_regular"
        android:textSize="16sp"
        android:textColor="@android:color/black"
        android:textAllCaps="false"
        android:text="Seguir" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button3"
        android:layout_width="200dp"
        android:layout_height="45dp"
        android:layout_below="@+id/button2"
        android:layout_marginTop="16dp"
        android:layout_centerHorizontal="true"
        android:background="@drawable/rounded_corner"
        android:fontFamily="@font/solway_regular"
        android:textSize="16sp"
        android:textColor="@android:color/black"
        android:textAllCaps="false"
        android:text="Não sei" />

</RelativeLayout>