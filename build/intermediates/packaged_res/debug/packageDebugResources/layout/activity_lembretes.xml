<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".LembretesActivity">

    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_alignParentTop="true">

        <TextView
            android:id="@+id/titulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Lembretes"
            android:fontFamily="@font/solway_regular"
            android:textSize="34sp" />

        <TextView
            android:id="@+id/sub_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/solway_regular"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Atividades"
            android:textSize="25sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/container_botoes_navegacao"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="@drawable/barranavegacao"
        android:clipChildren="false"
        android:elevation="4dp"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <ImageView
            android:id="@+id/botaohome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/botaohome"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name"
            android:background="@android:color/transparent" />

        <ImageView
            android:id="@+id/botaomaiscachorro"
            android:layout_width="0dp"
            android:layout_height="85dp"
            android:layout_marginBottom="6dp"
            android:layout_weight="1"
            android:src="@drawable/botaomaiscachorro"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name"
            android:background="@android:color/transparent" />

        <ImageView
            android:id="@+id/botaoperfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/botaoprofile"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name"
            android:background="@android:color/transparent" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewActivities"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerContainer"
        android:layout_above="@id/container_botoes_navegacao"
        tools:listitem="@layout/item_do_card_ativo" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddActivity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_above="@id/container_botoes_navegacao"
        android:layout_margin="16dp"
        android:contentDescription="Adicionar Atividade"
        android:src="@drawable/btn_adicionar"
        app:backgroundTint="#250" />

</RelativeLayout>