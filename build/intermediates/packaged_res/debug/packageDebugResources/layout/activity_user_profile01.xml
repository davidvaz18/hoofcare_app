<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UserProfileActivity01"
    android:background="@color/white"
    >
  <ImageButton
      android:id="@+id/btnBack"
      android:layout_width="60dp"
      android:layout_height="60dp"
      android:background="@android:color/transparent"
      android:src="@drawable/chevron_left"
      android:contentDescription="@string/app_name"
      android:layout_gravity="start|bottom"/>

    <ProgressBar
        android:layout_width="match_parent"
        android:id="@+id/topProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_height="8dp"
        android:layout_marginTop="55dp"
        android:max="100"
        android:progress="20"
        android:progressDrawable="@drawable/custom_progress_bar_green" />

  <ImageView
      android:id="@+id/cachorro_acariciado"
      android:layout_width="320dp"
      android:layout_height="135dp"
      android:layout_alignParentEnd="true"
      android:layout_marginTop="105dp"
      android:layout_marginEnd="41dp"
      android:src="@drawable/cachorro_acariciado_png" />


  <TextView
      android:id="@+id/textDescription"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_alignParentTop="true"
      android:layout_alignParentEnd="true"
      android:layout_marginTop="240dp"
      android:layout_marginEnd="0dp"
      android:gravity="center"
      android:fontFamily="@font/solway_regular"
      android:textSize="24sp"
      android:text="Qual seria a melhor \n descrição para você?" />

  <androidx.appcompat.widget.AppCompatButton
      android:id="@+id/button1"
      android:layout_width="300dp"
      android:layout_height="45dp"
      android:layout_below="@id/textDescription"
      android:layout_alignParentEnd="true"
      android:layout_marginTop="30dp"
      android:layout_marginEnd="54dp"
      android:background="@drawable/rounded_corner"
      android:text= "Acabei de adotar um cão."
      android:textColor="@android:color/black"
      android:fontFamily="@font/solway_regular"
      android:textSize="16sp"
      android:textAllCaps="false" />

  <androidx.appcompat.widget.AppCompatButton
      android:id="@+id/button3"
      android:layout_width="300dp"
      android:layout_height="45dp"
      android:layout_below="@id/button1"
      android:layout_alignParentEnd="true"
      android:layout_marginTop="16dp"
      android:layout_marginEnd="54dp"
      android:background="@drawable/rounded_corner"
      android:fontFamily="@font/solway_regular"
      android:textSize="16sp"
      android:text="O meu cão vive comigo."
      android:textColor="#000000"
      android:textAllCaps="false" />

  <androidx.appcompat.widget.AppCompatButton
      android:id="@+id/button2"
      android:layout_width="300dp"
      android:layout_height="45dp"
      android:layout_below="@id/button3"
      android:layout_alignParentEnd="true"
      android:layout_marginTop="16dp"
      android:layout_marginEnd="54dp"
      android:background="@drawable/rounded_corner"
      android:fontFamily="@font/solway_regular"
      android:textSize="16sp"
      android:textColor="@android:color/black"
      android:textAllCaps="false"
      android:text="Futuro tutor de pet." />



</RelativeLayout>



