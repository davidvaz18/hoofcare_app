<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">


        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start"
            android:background="@android:color/transparent"
            android:src="@drawable/chevron_left"
            android:contentDescription="Voltar" />


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Adicionar um pet"
            android:textSize="20sp"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/solway_regular"
            android:textColor="@android:color/black" />


        <ImageView
            android:id="@+id/imagePerfil"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="24dp"
            android:src="@drawable/add_photo_icone"
            android:scaleType="centerCrop"
            android:background="@drawable/rounded_corner"
            android:contentDescription="Foto do Pet" />


        <EditText
            android:id="@+id/etPetNome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome do Pet"
            android:inputType="textCapWords"
            android:layout_marginTop="16dp" />

        <Spinner
            android:id="@+id/spinnerRaca"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp" />


        <EditText
            android:id="@+id/etDescricao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Descrição e sinais distintos"
            android:inputType="textMultiLine"
            android:layout_marginTop="8dp" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:weightSum="2">

            <Spinner
                android:id="@+id/spinnerGenero"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="50dp" />


            <EditText
                android:id="@+id/etPeso"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="Peso (kg)"
                android:inputType="numberDecimal"
                android:maxLength="3" />
        </LinearLayout>




        <TextView
            android:id="@+id/tvDataNascimento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Aniversário"
            android:textSize="18sp"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:background="?android:attr/editTextBackground"
            android:drawableEnd="@android:drawable/ic_menu_my_calendar"
            android:drawablePadding="8dp"
            android:clickable="true"
            android:focusable="true" />



        <Button
            android:id="@+id/btnAdicionarPet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Adicionar à conta"
            android:layout_marginTop="32dp"
            android:backgroundTint="#52a447"
            android:textColor="@android:color/white" />

    </LinearLayout>
</ScrollView>
