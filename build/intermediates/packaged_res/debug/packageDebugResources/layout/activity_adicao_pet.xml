<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/adicaopet"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdicaoPetActivity">

    <RelativeLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/fotousuario"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_alignParentStart="true"
            android:src="@drawable/fotousuario" />

        <TextView
            android:id="@+id/textGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/fotousuario"
            android:layout_marginStart="16dp"
            android:layout_marginTop="6dp"
            tools:text="Olá!"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/dequemfalamoshoje"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/fotousuario"
            android:layout_marginTop="16dp"
            android:text="Meus Pets"
            android:textSize="20sp" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/container_botoes_navegacao"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="@drawable/barranavegacao"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <ImageView
            android:id="@+id/botaohome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/botaohome" />

        <ImageView
            android:id="@+id/botaomaiscachorro"
            android:layout_width="0dp"
            android:layout_height="85dp"
            android:layout_marginBottom="6dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/botaomaiscachorro" />

        <ImageView
            android:id="@+id/botaoperfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/botaoprofile" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewPets"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerContainer"
        android:layout_above="@id/container_botoes_navegacao"
        tools:listitem="@layout/item_dog_card" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/add_pet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/container_botoes_navegacao"
        android:layout_alignParentEnd="true"
        android:layout_margin="16dp"
        android:contentDescription="Adicionar Pet"
        android:src="@android:drawable/ic_input_add"
        app:tint="@android:color/white" />

</RelativeLayout>