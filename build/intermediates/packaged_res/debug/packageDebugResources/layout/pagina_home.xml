<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:id="@+id/container_com_padding"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:layout_above="@id/barraNavegacao">

        <ImageView
            android:id="@+id/fotousuario"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_alignParentStart="true"
            android:layout_marginStart="12dp"
            android:layout_marginTop="16dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/fotousuario" />

        <TextView
            android:id="@+id/textGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="29dp"
            android:layout_marginTop="22dp"
            android:layout_toEndOf="@id/fotousuario"
            android:fontFamily="@font/solway_regular"
            android:text="Olá!"
            android:textColor="#000"
            android:textSize="18sp" />


        <ImageButton
            android:id="@+id/configuracoes_btn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="25dp"
            android:layout_marginEnd="20dp"
            android:backgroundTint="@color/transparent"
            android:padding="16dp"
            android:src="@drawable/settings_icon" />

        <TextView
            android:id="@+id/dequemfalamoshoje"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="100dp"
            android:text="De quem falamos hoje?"
            android:fontFamily="@font/solway_regular"
            android:textColor="#000"
            android:textSize="20sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/botaopets"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_below="@id/dequemfalamoshoje"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/rounded_corner_less"
            android:text="Nome do cachorro"
            android:textColor="@android:color/white"
            android:fontFamily="@font/solway_regular"
            android:textStyle="bold"
            android:gravity="start|center_vertical"
            android:textSize="22sp"
            android:textAllCaps="false"
            android:paddingStart="16dp" />

        <View
            android:id="@+id/botaoPreto"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_below="@id/dequemfalamoshoje"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/botaopreto" />

        <LinearLayout
            android:id="@+id/linearBotoes"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_below="@id/botaopets"
            android:layout_marginTop="60dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:orientation="horizontal"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/botaoveterinario"
                android:layout_width="2dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/rounded_corner_less"
                android:text="Encontre\nClínicas veterinárias próximas de você"
                android:textColor="@android:color/white"
                android:fontFamily="@font/solway_regular"
                android:gravity="start|center_vertical"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <LinearLayout
                android:id="@+id/botaAlimentacao"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/rounded_corner_less"
                android:padding="16dp"
                android:layout_marginStart="12dp">

                <ImageView
                    android:id="@+id/imgAlimentacao"
                    android:layout_width="70dp"
                    android:layout_height="80dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:src="@drawable/imgalimentacao"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="1dp"
                    android:layout_marginTop="0dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lembretes"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/solway_regular"
                    android:layout_gravity="center_horizontal" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearBotoes2"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_below="@+id/linearBotoes"
            android:layout_marginTop="19dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/botaoSaude"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/rounded_corner_less"
                android:padding="16dp"
                android:layout_marginEnd="12dp">

                <ImageView
                    android:id="@+id/imgSaude"
                    android:layout_width="80dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="8dp"
                    android:src="@drawable/imgsaude" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saúde"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/solway_regular"
                    android:layout_gravity="center_horizontal" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/botaoTirarDuvidas"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/rounded_corner_less"
                android:padding="16dp"
                android:layout_marginStart="1dp">

                <ImageView
                    android:id="@+id/imgTirarDuvidas"
                    android:layout_width="80dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="8dp"
                    android:src="@drawable/imgduvidas" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tirar dúvidas"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/solway_regular"
                    android:layout_gravity="center_horizontal" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

    <ImageView
        android:id="@+id/barraNavegacao"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_alignParentBottom="true"
        android:scaleType="fitXY"
        android:src="@drawable/barranavegacao"
        android:contentDescription="@string/app_name" />

    <LinearLayout
        android:id="@+id/container_botoes_navegacao"
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <ImageView
            android:id="@+id/botaohome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/botaohome"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name"
            android:background="@android:color/transparent" />

        <ImageView
            android:id="@+id/botaomaiscachorro"
            android:layout_width="0dp"
            android:layout_height="85dp"
            android:layout_marginBottom="6dp"
            android:layout_weight="1"
            android:src="@drawable/botaomaiscachorro"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name"
            android:background="@android:color/transparent" />

        <ImageView
            android:id="@+id/botaoperfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/botaoprofile"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name"
            android:background="@android:color/transparent" />
    </LinearLayout>
</RelativeLayout>
